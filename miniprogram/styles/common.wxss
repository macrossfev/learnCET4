/* ========== 钢铁之翼 设计系统 ==========
   白/钢蓝/红 金属渐变主题
   ======================================== */

/* 主题色 */
.primary-color { color: #2B5EA7; }
.primary-bg { background: linear-gradient(135deg, #3674B8, #1E4D8C); }
.success-color { color: #1A8A5C; }
.danger-color { color: #C62828; }
.warn-color { color: #D4860B; }
.muted-color { color: #8494A7; }

/* 容器 */
.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 卡片 - 金属质感 */
.card {
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8FC 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 60, 110, 0.08), 0 1rpx 3rpx rgba(30, 60, 110, 0.05);
  border: 1rpx solid rgba(180, 195, 220, 0.35);
}

/* 按钮 - 基础 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  letter-spacing: 1rpx;
}

.btn::after { border: none; }

/* 主按钮 - 钢蓝金属渐变 */
.btn-primary {
  background: linear-gradient(135deg, #3674B8 0%, #1E4D8C 50%, #2B5EA7 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(30, 77, 140, 0.35);
}

.btn-primary:active {
  background: linear-gradient(135deg, #2B5EA7 0%, #163D6F 50%, #1E4D8C 100%);
  box-shadow: 0 2rpx 6rpx rgba(30, 77, 140, 0.4);
}

/* 描边按钮 */
.btn-outline {
  background: linear-gradient(180deg, #FFFFFF, #F4F6FA);
  color: #2B5EA7;
  border: 2rpx solid #B0C4DE;
  box-shadow: 0 2rpx 6rpx rgba(30, 60, 110, 0.06);
}

.btn-outline:active {
  background: linear-gradient(180deg, #EDF1F8, #E4E9F2);
}

/* 成功按钮 - 绿金属 */
.btn-success {
  background: linear-gradient(135deg, #22A06B 0%, #1A7A52 50%, #1E8C5E 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(26, 122, 82, 0.3);
}

.btn-success:active {
  background: linear-gradient(135deg, #1A7A52, #14614A);
}

/* 危险按钮 - 红金属 */
.btn-danger {
  background: linear-gradient(135deg, #D32F2F 0%, #B71C1C 50%, #C62828 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(183, 28, 28, 0.3);
}

.btn-danger:active {
  background: linear-gradient(135deg, #B71C1C, #8E1515);
}

/* 灰按钮 - 银灰金属 */
.btn-gray {
  background: linear-gradient(180deg, #E8ECF2, #D5DAE3);
  color: #4A5568;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.btn-gray:active {
  background: linear-gradient(180deg, #D5DAE3, #C8CED8);
}

.btn-small {
  height: 64rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  padding: 0 32rpx;
}

/* 文字 */
.text-large { font-size: 48rpx; }
.text-title { font-size: 36rpx; }
.text-body { font-size: 28rpx; }
.text-small { font-size: 24rpx; }
.text-center { text-align: center; }
.text-bold { font-weight: 600; }

/* 间距 */
.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 24rpx; }
.mt-lg { margin-top: 40rpx; }
.mb-sm { margin-bottom: 16rpx; }
.mb-md { margin-bottom: 24rpx; }
.mb-lg { margin-bottom: 40rpx; }

/* Flex */
.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }

/* 进度条 - 钢蓝金属渐变 */
.progress-wrap {
  height: 16rpx;
  background: linear-gradient(180deg, #E0E5EE, #D0D6E1);
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: inset 0 1rpx 3rpx rgba(0, 0, 0, 0.08);
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #3674B8, #5A9AD9, #3674B8);
  border-radius: 8rpx;
  transition: width 0.3s ease;
  box-shadow: 0 1rpx 4rpx rgba(54, 116, 184, 0.4);
}

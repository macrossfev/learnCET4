@import '/styles/common.wxss';

.container {
  background: linear-gradient(180deg, #E8EDF5 0%, #F0F2F7 40%, #F0F2F7 100%);
}

/* 统计网格 2x2 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  box-sizing: border-box;
}

.stat-number {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #2B5EA7, #3674B8, #5A9AD9);
  -webkit-background-clip: text;
  color: transparent;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: #8494A7;
  margin-top: 8rpx;
}

/* 正确率卡片 */
.accuracy-card {
  padding: 30rpx;
}

.accuracy-title {
  font-size: 30rpx;
  color: #1a2a3a;
  font-weight: 600;
}

.accuracy-value {
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #1A8A5C, #22A06B);
  -webkit-background-clip: text;
  color: transparent;
}

/* 进度卡片 */
.progress-card {
  padding: 30rpx;
}

.progress-title {
  margin-bottom: 20rpx;
  font-size: 30rpx;
  color: #1a2a3a;
  font-weight: 600;
}

/* 预计完成卡片 */
.estimate-card {
  padding: 30rpx;
}

.estimate-title {
  font-size: 30rpx;
  color: #1a2a3a;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.estimate-content {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.estimate-days {
  font-size: 48rpx;
  font-weight: 700;
  color: #D4860B;
}

.estimate-hint {
  font-size: 26rpx;
  color: #8494A7;
}

/* 学习趋势卡片 */
.trend-card {
  padding: 30rpx;
}

.trend-title {
  font-size: 30rpx;
  color: #1a2a3a;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.trend-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 200rpx;
  padding: 0 10rpx;
}

.trend-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.trend-day {
  font-size: 22rpx;
  color: #8494A7;
}

.trend-bar-wrap {
  width: 40rpx;
  height: 140rpx;
  background: linear-gradient(180deg, #E8EDF5, #D8DEE8);
  border-radius: 8rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 4rpx;
  box-sizing: border-box;
}

.trend-bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #5A9AD9, #2B5EA7);
  border-radius: 6rpx;
  transition: height 0.3s ease;
  min-height: 10%;
}

.trend-value {
  font-size: 20rpx;
  color: #2B5EA7;
  font-weight: 600;
}

/* 成就徽章卡片 */
.badges-card {
  padding: 30rpx;
}

.badges-title {
  font-size: 30rpx;
  color: #1a2a3a;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.badges-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.badge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
  padding: 16rpx 8rpx;
  background: linear-gradient(180deg, #F8F9FC, #F0F2F7);
  border-radius: 12rpx;
  border: 2rpx solid rgba(180, 195, 220, 0.3);
}

.badge-item.unlocked {
  border-color: #FFD700;
  background: linear-gradient(180deg, #FFFBEB, #FFF3D0);
}

.badge-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
  filter: grayscale(100%);
  opacity: 0.5;
}

.badge-item.unlocked .badge-icon {
  filter: grayscale(0%);
  opacity: 1;
}

.badge-name {
  font-size: 20rpx;
  color: #8494A7;
  text-align: center;
  line-height: 1.3;
}

.badge-item.unlocked .badge-name {
  color: #D4860B;
  font-weight: 600;
}

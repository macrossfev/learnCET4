<view class="container" wx:if="{{!loading}}">
  <!-- 数字统计卡片 2x2 网格 -->
  <view class="card stats-grid">
    <view class="stat-item">
      <text class="stat-number">{{totalLearned}}</text>
      <text class="stat-label">已学单词</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{streakDays}}</text>
      <text class="stat-label">连续打卡 (天)</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{todayLearned}}</text>
      <text class="stat-label">今日已学</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">{{todayReview}}</text>
      <text class="stat-label">今日待复习</text>
    </view>
  </view>

  <!-- 测试正确率 -->
  <view class="card accuracy-card">
    <view class="flex-between">
      <text class="accuracy-title">测试正确率</text>
      <text class="accuracy-value">{{testAccuracy}}%</text>
    </view>
  </view>

  <!-- 总进度条 -->
  <view class="card progress-card">
    <view class="progress-title flex-between">
      <text>总进度</text>
      <text class="muted-color text-small">{{totalLearned}} / {{totalWords}}</text>
    </view>
    <progress-bar percent="{{progressPercent}}" showLabel="{{true}}" label="已掌握" />
  </view>

  <!-- 预计完成时间 -->
  <view class="card estimate-card">
    <view class="estimate-title">📅 预计完成</view>
    <view class="estimate-content">
      <text class="estimate-days">{{estimatedDays}} 天</text>
      <text class="estimate-hint">按当前进度，每天 {{dailyCount}} 词</text>
    </view>
  </view>

  <!-- 近 7 天学习趋势 -->
  <view class="card trend-card">
    <view class="trend-title">📊 近 7 天学习</view>
    <view class="trend-chart">
      <view class="trend-bar" wx:for="{{weeklyTrend}}" wx:key="day">
        <view class="trend-day">{{item.day}}</view>
        <view class="trend-bar-wrap">
          <view class="trend-bar-fill" style="height: {{item.learned > 0 ? Math.max(10, item.learned / 30 * 100) : 10}}%"></view>
        </view>
        <view class="trend-value">{{item.learned}}</view>
      </view>
    </view>
  </view>

  <!-- 成就徽章 -->
  <view class="card badges-card">
    <view class="badges-title">🏅 成就徽章</view>
    <view class="badges-grid">
      <view class="badge-item {{badge.unlocked ? 'unlocked' : 'locked'}}" wx:for="{{badges}}" wx:key="name">
        <view class="badge-icon">{{badge.icon}}</view>
        <view class="badge-name">{{badge.name}}</view>
      </view>
    </view>
  </view>

  <!-- 复习统计 -->
  <view class="card review-stats-card" wx:if="{{reviewStats.totalReviews > 0 || reviewStats.difficultWords.length > 0}}">
    <view class="card-title">📊 复习统计</view>
    
    <view class="stats-row" wx:if="{{reviewStats.totalReviews > 0}}">
      <view class="stat-box">
        <text class="stat-value">{{reviewStats.totalReviews}}</text>
        <text class="stat-label">累计复习</text>
      </view>
      <view class="stat-box">
        <text class="stat-value {{reviewStats.masteryRate >= 80 ? 'high' : 'medium'}}">{{reviewStats.masteryRate}}%</text>
        <text class="stat-label">掌握率</text>
      </view>
    </view>
    
    <view class="difficult-section" wx:if="{{reviewStats.difficultWords.length > 0}}">
      <text class="difficult-title">⚠️ 高频遗忘单词</text>
      <view class="difficult-list">
        <view class="difficult-item" wx:for="{{reviewStats.difficultWords}}" wx:key="word">
          <text class="difficult-word">{{item.word}}</text>
          <text class="difficult-count">遗忘 {{item.forgottenCount}} 次</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 加载中 -->
<view class="container flex-center" wx:else>
  <text class="muted-color">加载中...</text>
</view>

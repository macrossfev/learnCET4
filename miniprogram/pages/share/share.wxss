.share-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1E4D8C 0%, #2B5EA7 100%);
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-card {
  width: 100%;
  max-width: 600rpx;
  background: linear-gradient(180deg, #FFFFFF, #F7F8FC);
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 40rpx;
}

.card-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.app-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1E4D8C;
  margin-bottom: 12rpx;
}

.app-slogan {
  display: block;
  font-size: 28rpx;
  color: #8494A7;
}

.card-stats {
  margin-bottom: 48rpx;
}

.stat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(180, 195, 220, 0.2);
}

.stat-row:last-child {
  border-bottom: none;
}

.stat-icon {
  font-size: 40rpx;
  width: 60rpx;
}

.stat-label {
  font-size: 30rpx;
  color: #6B7B8D;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #2B5EA7;
}

.card-footer {
  text-align: center;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(180, 195, 220, 0.3);
}

.date {
  display: block;
  font-size: 26rpx;
  color: #8494A7;
  margin-bottom: 12rpx;
}

.encourage {
  display: block;
  font-size: 30rpx;
  color: #1E4D8C;
  font-weight: 600;
}

.qr-section {
  display: flex;
  justify-content: center;
  margin-top: 36rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed rgba(180, 195, 220, 0.4);
}

.qr-placeholder {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(180deg, #F0F2F7, #E8EDF5);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #B0C4DE;
}

.qr-hint {
  font-size: 24rpx;
  color: #8494A7;
}

.action-buttons {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #1E4D8C;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

@import '/styles/common.wxss';

.container {
  padding: 30rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #E8EDF5 0%, #F0F2F7 40%, #F0F2F7 100%);
}

/* 进度头部 */
.progress-header {
  margin-bottom: 32rpx;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2B5EA7, #3674B8);
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 16rpx;
}

/* 题目卡片 - 金属面板 */
.question-card {
  text-align: center;
  padding: 48rpx 36rpx;
  margin-bottom: 40rpx;
}

.question-word {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 12rpx;
}

.question-phonetic {
  display: block;
  font-size: 28rpx;
  color: #8494A7;
  margin-bottom: 20rpx;
}

.question-hint {
  display: block;
  font-size: 26rpx;
  color: #B0C4DE;
}

/* 选项列表 - 金属面板选项 */
.options-list {
  margin-bottom: 40rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(180, 195, 220, 0.3);
  transition: all 0.2s ease;
  position: relative;
  background: linear-gradient(180deg, #FFFFFF, #F7F8FC);
}

.option-item:active {
  background: linear-gradient(180deg, #EDF1F8, #E4E9F2);
}

.option-label {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #E8ECF2, #D5DAE3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #4A5568;
  margin-right: 24rpx;
  flex-shrink: 0;
  text-align: center;
  line-height: 56rpx;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #1a2a3a;
  line-height: 1.5;
}

.option-icon {
  font-size: 36rpx;
  color: #1A8A5C;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.wrong-icon {
  color: #C62828;
}

/* 选中状态 - 钢蓝高亮 */
.option-selected {
  border-color: #3674B8;
  background: linear-gradient(180deg, #EDF3FB, #E2EAF6);
}

.option-selected .option-label {
  background: linear-gradient(135deg, #3674B8, #1E4D8C);
  color: #ffffff;
}

/* 正确状态 - 绿金属 */
.option-correct {
  border-color: #1A8A5C;
  background: linear-gradient(180deg, #EDFAF0, #E0F5E4);
}

.option-correct .option-label {
  background: linear-gradient(135deg, #22A06B, #1A7A52);
  color: #ffffff;
}

.option-correct .option-text {
  color: #1A8A5C;
  font-weight: 600;
}

/* 错误状态 - 红金属 */
.option-wrong {
  border-color: #C62828;
  background: linear-gradient(180deg, #FDF0F0, #FAE4E4);
}

.option-wrong .option-label {
  background: linear-gradient(135deg, #D32F2F, #B71C1C);
  color: #ffffff;
}

.option-wrong .option-text {
  color: #C62828;
}

/* 底部操作 */
.bottom-action {
  padding-bottom: 60rpx;
}

/* 结果页 */
.result-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  width: 100%;
}

.result-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 48rpx;
}

.score-circle {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 20rpx;
}

.score-num {
  font-size: 96rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #2B5EA7, #3674B8, #5A9AD9);
  -webkit-background-clip: text;
  color: transparent;
}

.score-total {
  font-size: 40rpx;
  color: #8494A7;
  margin-left: 4rpx;
}

.score-percent {
  font-size: 30rpx;
  color: #4A5568;
  margin-bottom: 60rpx;
}

.result-btns {
  display: flex;
  width: 100%;
  gap: 24rpx;
}

.result-btn {
  flex: 1;
}

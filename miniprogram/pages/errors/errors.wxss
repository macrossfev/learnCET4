@import '/styles/common.wxss';

.container {
  background: linear-gradient(180deg, #E8EDF5 0%, #F0F2F7 40%, #F0F2F7 100%);
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 智能统计卡片 */
.stats-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8FC 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 20rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 60, 110, 0.08);
  border: 1rpx solid rgba(180, 195, 220, 0.35);
}

.stats-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: linear-gradient(180deg, #F8F9FC, #F0F2F7);
  border-radius: 12rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2B5EA7;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #8494A7;
  text-align: center;
}

/* 推荐练习区域 */
.recommend-section {
  background: linear-gradient(180deg, #FFF8E1, #FFECB3);
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 20rpx 30rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.3);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 8rpx;
}

.section-desc {
  display: block;
  font-size: 24rpx;
  color: #B08D55;
}

.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.recommend-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 134, 11, 0.2);
  min-width: 200rpx;
}

.recommend-word {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2a3a;
  margin-right: 12rpx;
}

.recommend-count {
  font-size: 22rpx;
  color: #D4860B;
}

.recommend-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #4A5568;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #8494A7;
}

/* 日期分组 - 金属面板 */
.day-group {
  margin-bottom: 20rpx;
}

.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(180deg, #FFFFFF, #F7F8FC);
  padding: 24rpx 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(30, 60, 110, 0.06);
  border: 1rpx solid rgba(180, 195, 220, 0.3);
}

.day-left {
  display: flex;
  align-items: center;
}

.day-date {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-right: 16rpx;
}

.day-count {
  font-size: 24rpx;
  color: #C62828;
  background: linear-gradient(180deg, #FDF0F0, #FAE4E4);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(198, 40, 40, 0.15);
}

.day-arrow {
  font-size: 28rpx;
  color: #B0C4DE;
}

/* 错题条目 - 红色金属左边框 */
.day-errors {
  padding: 0 8rpx;
}

.error-item {
  background: linear-gradient(180deg, #FFFFFF, #F7F8FC);
  margin-top: 12rpx;
  padding: 24rpx 28rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #C62828;
  box-shadow: 0 2rpx 8rpx rgba(30, 60, 110, 0.05);
  border-top: 1rpx solid rgba(180, 195, 220, 0.2);
  border-right: 1rpx solid rgba(180, 195, 220, 0.2);
  border-bottom: 1rpx solid rgba(180, 195, 220, 0.2);
}

.error-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.error-word {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2a3a;
}

.error-type {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.type-choice {
  background: linear-gradient(135deg, rgba(54, 116, 184, 0.12), rgba(54, 116, 184, 0.06));
  color: #2B5EA7;
  border: 1rpx solid rgba(54, 116, 184, 0.2);
}

.type-spell {
  background: linear-gradient(135deg, rgba(212, 134, 11, 0.12), rgba(212, 134, 11, 0.06));
  color: #D4860B;
  border: 1rpx solid rgba(212, 134, 11, 0.2);
}

.error-meaning {
  display: block;
  font-size: 26rpx;
  color: #6B7B8D;
  margin-bottom: 16rpx;
}

.error-answers {
  background: linear-gradient(180deg, #F5F7FB, #EEF1F7);
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(180, 195, 220, 0.25);
}

.answer-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.answer-row:last-child {
  margin-bottom: 0;
}

.answer-label {
  font-size: 24rpx;
  width: 120rpx;
  flex-shrink: 0;
}

.wrong-label {
  color: #C62828;
}

.correct-label {
  color: #1A8A5C;
}

.answer-value {
  font-size: 26rpx;
  color: #1a2a3a;
}

.wrong-value {
  text-decoration: line-through;
  color: #C62828;
}

.correct-value {
  color: #1A8A5C;
  font-weight: 500;
}

/* 清空按钮 - 金属底栏 */
.clear-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #F0F2F7, #E8EDF5);
  border-top: 1rpx solid rgba(180, 195, 220, 0.3);
}

.clear-btn {
  font-size: 28rpx;
}

/* 全部测试按钮 */
.test-all-section {
  padding: 20rpx 30rpx;
  margin-bottom: 10rpx;
}

.test-all-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 日期行布局 */
.date-row {
  display: flex;
  align-items: center;
}

.day-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-test-day {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  height: auto;
  line-height: 1.4;
  background: linear-gradient(135deg, #2B5EA7, #3674B8);
  color: #fff;
  border-radius: 20rpx;
  border: none;
}

.btn-test-day::after {
  border: none;
}

/* 错题条目布局调整 */
.error-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.error-content {
  flex: 1;
}

.error-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(180, 195, 220, 0.2);
}

.btn-action-review,
.btn-action-master {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
}

.btn-action-review::after,
.btn-action-master::after {
  border: none;
}

.btn-action-review {
  background: linear-gradient(180deg, #F0F2F7, #E4E9F0);
  color: #2B5EA7;
}

.btn-action-master {
  background: linear-gradient(180deg, #EDFAF0, #E0F5E4);
  color: #1A8A5C;
}

/* 标记掌握确认弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: linear-gradient(180deg, #FFFFFF, #F7F8FC);
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  width: 80%;
  max-width: 560rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(30, 60, 110, 0.15);
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 16rpx;
}

.modal-word {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #2B5EA7;
  margin-bottom: 12rpx;
}

.modal-desc {
  display: block;
  font-size: 26rpx;
  color: #6B7B8D;
  margin-bottom: 32rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: linear-gradient(180deg, #F0F2F7, #E4E9F0);
  color: #6B7B8D;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #1A8A5C, #2BA87C);
  color: #fff;
}

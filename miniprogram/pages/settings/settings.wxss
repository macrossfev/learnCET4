@import '/styles/common.wxss';

.container {
  background: linear-gradient(180deg, #E8EDF5 0%, #F0F2F7 40%, #F0F2F7 100%);
}

/* 分组标题 */
.section-title {
  font-size: 26rpx;
  color: #8494A7;
  padding: 16rpx 8rpx 8rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 设置组卡片 */
.settings-group {
  padding: 0;
  overflow: hidden;
}

/* 设置项 */
.setting-item {
  padding: 30rpx;
  min-height: 48rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #1a2a3a;
  font-weight: 500;
}

.setting-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #4A5568;
}

.setting-info {
  font-size: 28rpx;
  color: #8494A7;
}

.arrow {
  font-size: 28rpx;
  color: #B0C4DE;
  margin-left: 12rpx;
}

/* 分割线 - 金属细线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(180, 195, 220, 0.4), transparent);
  margin: 0 30rpx;
}

/* 缓存信息 */
.cache-info {
  display: flex;
  flex-direction: column;
}

.cache-detail {
  font-size: 24rpx;
  color: #8494A7;
  margin-top: 4rpx;
}

/* 缓存进度条 */
.cache-progress {
  display: flex;
  align-items: center;
  padding: 0 30rpx 20rpx;
  gap: 16rpx;
}

.cache-progress-bar {
  flex: 1;
  height: 8rpx;
  background: linear-gradient(180deg, #E8EDF5, #D8DEE8);
  border-radius: 4rpx;
  overflow: hidden;
}

.cache-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2B5EA7, #5A9AD9);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.cache-percent {
  font-size: 22rpx;
  color: #8494A7;
  min-width: 50rpx;
  text-align: right;
}

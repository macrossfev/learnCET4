@import '/styles/common.wxss';

.container {
  background: linear-gradient(180deg, #E8EDF5 0%, #F0F2F7 40%, #F0F2F7 100%);
}

/* 分组标题 */
.section-title {
  font-size: 26rpx;
  color: #8494A7;
  padding: 16rpx 8rpx 8rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 设置组卡片 */
.settings-group {
  padding: 0;
  overflow: hidden;
}

/* 设置项 */
.setting-item {
  padding: 30rpx;
  min-height: 48rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #1a2a3a;
  font-weight: 500;
}

.setting-value {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #4A5568;
}

.setting-info {
  font-size: 28rpx;
  color: #8494A7;
}

.arrow {
  font-size: 28rpx;
  color: #B0C4DE;
  margin-left: 12rpx;
}

/* 分割线 - 金属细线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(180, 195, 220, 0.4), transparent);
  margin: 0 30rpx;
}

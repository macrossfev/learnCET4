.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1E4D8C 0%, #2B5EA7 100%);
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

/* 顶部统计 */
.header-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
}

.review-count {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 20rpx 40rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
}

.count-number {
  font-size: 56rpx;
  font-weight: 800;
  color: #FFD700;
  line-height: 1;
}

.count-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.no-review-text {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
  padding: 20rpx 40rpx;
  border-radius: 24rpx;
}

/* 模式列表 */
.mode-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.mode-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s;
}

.mode-item:active {
  transform: scale(0.98);
}

.mode-item.recommended {
  border: 2rpx solid #FFD700;
  box-shadow: 0 4rpx 16rpx rgba(255, 215, 0, 0.3);
}

.mode-item.blue { border-left: 8rpx solid #2B5EA7; }
.mode-item.green { border-left: 8rpx solid #1A8A5C; }
.mode-item.orange { border-left: 8rpx solid #D4860B; }
.mode-item.red { border-left: 8rpx solid #C62828; }

.mode-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.mode-icon {
  font-size: 48rpx;
}

.mode-badge {
  background: linear-gradient(135deg, #FFD700, #FFC107);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #1a2a3a;
  font-weight: 600;
}

.mode-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 8rpx;
}

.mode-desc {
  display: block;
  font-size: 26rpx;
  color: #8494A7;
  margin-bottom: 20rpx;
}

.mode-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.mode-time {
  font-size: 24rpx;
  color: #6B7B8D;
}

.mode-arrow {
  font-size: 40rpx;
  color: #B0C4DE;
  font-weight: 300;
}

/* 底部提示 */
.footer-tip {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.tip-text {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

@import '/styles/common.wxss';

.container {
  background: linear-gradient(180deg, #E8EDF5 0%, #F0F2F7 40%, #F0F2F7 100%);
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0 16rpx;
}

.progress-text {
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2B5EA7, #3674B8);
  -webkit-background-clip: text;
  color: transparent;
}

.step-indicator {
  font-size: 24rpx;
  color: #8494A7;
  background: rgba(43, 94, 167, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* 学习进度条 */
.learn-progress-bar {
  height: 8rpx;
  background: linear-gradient(180deg, #D8DEE8, #CDD4E0);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.learn-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3674B8, #5A9AD9, #3674B8);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 卡片区域 */
.card-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 0 200rpx;
}

/* 单词展示 */
.word-display {
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8FC 100%);
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 60, 110, 0.08);
  border: 1rpx solid rgba(180, 195, 220, 0.35);
}

.word-text {
  display: block;
  text-align: center;
  font-size: 64rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 8rpx;
}

.word-phonetic {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #8494A7;
  margin-bottom: 24rpx;
}

.word-meaning-box {
  text-align: center;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(180, 195, 220, 0.3);
  border-bottom: 1rpx solid rgba(180, 195, 220, 0.3);
  margin-bottom: 24rpx;
}

.word-meaning {
  font-size: 36rpx;
  color: #2B5EA7;
  font-weight: 500;
}

.word-section {
  margin-top: 24rpx;
}

.section-label {
  display: block;
  font-size: 24rpx;
  color: #8494A7;
  margin-bottom: 8rpx;
}

.section-en {
  display: block;
  font-size: 28rpx;
  color: #1a2a3a;
  margin-bottom: 4rpx;
  line-height: 1.5;
}

.section-cn {
  display: block;
  font-size: 26rpx;
  color: #6B7B8D;
  line-height: 1.5;
}

.swipe-hint {
  text-align: center;
  padding: 20rpx 0;
}

.swipe-hint-text {
  font-size: 24rpx;
  color: #B0C4DE;
}

/* 完成状态 */
.done-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 100rpx;
}

.done-icon-text {
  font-size: 96rpx;
  color: #1A8A5C;
  margin-bottom: 20rpx;
}

.done-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 12rpx;
}

.done-sub {
  font-size: 28rpx;
  color: #8494A7;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #FFFFFF, #F4F6FA);
  box-shadow: 0 -4rpx 16rpx rgba(30, 60, 110, 0.08);
  border-top: 1rpx solid rgba(180, 195, 220, 0.3);
}

.btn-action {
  flex: 1;
  margin: 0 10rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-warning {
  background: linear-gradient(135deg, #D4860B, #E6A020);
  color: #FFFFFF;
}

.btn-action[disabled] {
  opacity: 0.4;
}

/* 测试阶段 */
.quiz-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 0 200rpx;
}

.quiz-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8FC 100%);
  border-radius: 20rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 60, 110, 0.08);
  border: 1rpx solid rgba(180, 195, 220, 0.35);
}

.quiz-word {
  display: block;
  text-align: center;
  font-size: 56rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 8rpx;
}

.quiz-phonetic {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #8494A7;
  margin-bottom: 24rpx;
}

.quiz-meaning-large {
  display: block;
  text-align: center;
  font-size: 48rpx;
  font-weight: 600;
  color: #1a2a3a;
  margin-bottom: 32rpx;
}

.quiz-prompt {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #8494A7;
  margin-bottom: 36rpx;
}

/* 选择题 */
.choice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.choice-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(180deg, #F8F9FC, #F0F2F7);
  border-radius: 12rpx;
  border: 2rpx solid rgba(180, 195, 220, 0.3);
}

.choice-letter {
  font-size: 28rpx;
  font-weight: 700;
  color: #2B5EA7;
  margin-right: 20rpx;
  width: 40rpx;
}

.choice-text {
  font-size: 30rpx;
  color: #1a2a3a;
}

.choice-correct {
  background: linear-gradient(180deg, #EDFAF0, #E0F5E4);
  border-color: #1A8A5C;
}

.choice-correct .choice-text {
  color: #1A8A5C;
  font-weight: 600;
}

.choice-wrong {
  background: linear-gradient(180deg, #FDF0F0, #FAE4E4);
  border-color: #C62828;
}

.choice-wrong .choice-text {
  color: #C62828;
}

.choice-feedback {
  text-align: center;
  margin-top: 20rpx;
}

.feedback-text {
  font-size: 28rpx;
  color: #C62828;
}

/* 填词输入 */
.spell-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #B0C4DE;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1a2a3a;
  margin-bottom: 16rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #FFFFFF, #FAFBFD);
}

.spell-input.spell-wrong {
  border-color: #C62828;
  background: linear-gradient(180deg, #FFF5F5, #FFF0F0);
}

.spell-hint {
  text-align: center;
  margin-bottom: 16rpx;
}

.spell-hint text {
  font-size: 26rpx;
  color: #C62828;
}

.spell-submit-btn {
  margin-top: 10rpx;
}

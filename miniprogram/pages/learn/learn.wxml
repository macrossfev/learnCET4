<view class="container" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">
  <!-- 顶部进度 -->
  <view class="top-bar">
    <text class="progress-text">{{currentIndex + 1}} / {{words.length}}</text>
    <text class="step-indicator">步骤 {{step}}/3</text>
  </view>

  <!-- 进度条 -->
  <view class="learn-progress-bar">
    <view class="learn-progress-fill" style="width: {{words.length > 0 ? (currentIndex + 1) / words.length * 100 : 0}}%;"></view>
  </view>

  <!-- ===== 步骤1：单词展示 ===== -->
  <view class="card-area" wx:if="{{words.length > 0 && !allDone && step === 1}}">
    <view class="word-display">
      <text class="word-text">{{words[currentIndex].word}}</text>
      <text class="word-phonetic">{{words[currentIndex].phonetic}}</text>
      <view class="word-meaning-box">
        <text class="word-meaning">{{words[currentIndex].meaning}}</text>
      </view>

      <view class="word-section" wx:if="{{words[currentIndex].phrase}}">
        <text class="section-label">词组</text>
        <text class="section-en">{{words[currentIndex].phrase}}</text>
        <text class="section-cn">{{words[currentIndex].phrase_meaning}}</text>
      </view>

      <view class="word-section" wx:if="{{words[currentIndex].example}}">
        <text class="section-label">例句</text>
        <text class="section-en">{{words[currentIndex].example}}</text>
        <text class="section-cn">{{words[currentIndex].example_meaning}}</text>
      </view>
    </view>

    <view class="swipe-hint">
      <text class="swipe-hint-text">右滑进入测试 →</text>
    </view>
  </view>

  <!-- ===== 步骤2：选择题 ===== -->
  <view class="quiz-area" wx:if="{{step === 2 && words.length > 0}}">
    <view class="quiz-card">
      <text class="quiz-word">{{words[currentIndex].word}}</text>
      <text class="quiz-phonetic">{{words[currentIndex].phonetic}}</text>
      <text class="quiz-prompt">请选择正确的中文含义</text>

      <view class="choice-list">
        <view wx:for="{{choiceOptions}}" wx:key="index" class="choice-item {{choiceSelected === index ? (item.correct ? 'choice-correct' : 'choice-wrong') : ''}}" data-index="{{index}}" bind:tap="onChoiceSelect">
          <text class="choice-letter">{{['A','B','C','D'][index]}}</text>
          <text class="choice-text">{{item.meaning}}</text>
        </view>
      </view>

      <view class="choice-feedback" wx:if="{{choiceWrong}}">
        <text class="feedback-text">答案错误，请重试</text>
      </view>
    </view>

    <view class="swipe-hint">
      <text class="swipe-hint-text">← 左滑返回 | 右滑跳过 →</text>
    </view>
  </view>

  <!-- ===== 步骤3：填词 ===== -->
  <view class="quiz-area" wx:if="{{step === 3 && words.length > 0}}">
    <view class="quiz-card">
      <text class="quiz-meaning-large">{{words[currentIndex].meaning}}</text>
      <text class="quiz-prompt">请输入对应的英文单词</text>

      <input class="spell-input {{spellWrong ? 'spell-wrong' : ''}}" value="{{spellInput}}" bindinput="onSpellInput" bindconfirm="onSpellSubmit" focus="{{step === 3}}" placeholder="输入单词..." adjust-position="{{true}}" />

      <view class="spell-hint" wx:if="{{spellHint}}">
        <text>{{spellHint}}</text>
      </view>

      <button class="btn btn-primary spell-submit-btn" bind:tap="onSpellSubmit">确认</button>
    </view>

    <view class="swipe-hint">
      <text class="swipe-hint-text">← 左滑返回选择题</text>
    </view>
  </view>

  <!-- 完成状态 -->
  <view class="done-state" wx:if="{{allDone}}">
    <text class="done-icon-text">✅</text>
    <text class="done-title">学习完成</text>
    <text class="done-sub">本单元已全部掌握</text>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{words.length > 0 && !allDone}}">
    <button class="btn btn-gray btn-action" disabled="{{currentIndex <= 0}}" bind:tap="onPrevWord">上一词</button>
    <button class="btn btn-warning btn-action" bind:tap="onMarkUnfamiliar">不熟</button>
    <button class="btn btn-primary btn-action" bind:tap="onNextWord">{{step < 3 ? '请先完成测试' : '下一词'}}</button>
  </view>

  <!-- 学习完成庆祝动画 -->
  <celebration show="{{showCelebration}}" type="both" duration="{{3000}}" bind:complete="onCelebrationComplete" />
</view>
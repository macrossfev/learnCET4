@import '/styles/common.wxss';

.container {
  background: linear-gradient(180deg, #E8EDF5 0%, #F0F2F7 40%, #F0F2F7 100%);
}

/* 欢迎区域 - 金属蓝标题 */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 24rpx;
}

.welcome-title {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #1E4D8C, #3674B8, #5A9AD9);
  -webkit-background-clip: text;
  color: transparent;
  letter-spacing: 4rpx;
}

.welcome-sub {
  font-size: 26rpx;
  color: #8494A7;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx 0 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a2a3a;
}

/* 打卡角标 - 红色金属 */
.streak-badge {
  background: linear-gradient(135deg, #E53935, #C62828);
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(198, 40, 40, 0.3);
}

.streak-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 任务卡片 - 金属面板 */
.task-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FB 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 60, 110, 0.08), 0 1rpx 3rpx rgba(30, 60, 110, 0.05);
  border: 1rpx solid rgba(180, 195, 220, 0.35);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-info {
  flex: 1;
}

.task-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2a3a;
  display: block;
  margin-bottom: 12rpx;
}

.task-numbers {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.task-done {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #2B5EA7, #3674B8);
  -webkit-background-clip: text;
  color: transparent;
}

.task-sep {
  font-size: 32rpx;
  color: #B0C4DE;
  margin: 0 6rpx;
}

.task-total {
  font-size: 32rpx;
  color: #8494A7;
}

.task-unit {
  font-size: 26rpx;
  color: #8494A7;
  margin-left: 8rpx;
}

.review-count {
  background: linear-gradient(135deg, #D32F2F, #E53935);
  -webkit-background-clip: text;
  color: transparent;
}

.task-hint {
  font-size: 24rpx;
  color: #8494A7;
}

.task-hint.task-complete {
  color: #1A8A5C;
}

.task-action {
  margin-left: 20rpx;
  flex-shrink: 0;
}

/* 复习按钮角标 - 红色金属 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, #E53935, #C62828);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
  position: relative;
  top: -2rpx;
  box-shadow: 0 2rpx 6rpx rgba(198, 40, 40, 0.3);
}

/* 进度区域 - 金属面板 */
.progress-section {
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FB 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 60, 110, 0.08), 0 1rpx 3rpx rgba(30, 60, 110, 0.05);
  border: 1rpx solid rgba(180, 195, 220, 0.35);
}

.progress-num {
  font-size: 26rpx;
  color: #8494A7;
}

/* 底部打卡区域 */
.streak-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  padding: 30rpx 0;
}

.streak-icon-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.streak-number {
  font-size: 80rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #D32F2F, #E53935, #FF5252);
  -webkit-background-clip: text;
  color: transparent;
}

.streak-label {
  font-size: 28rpx;
  color: #C62828;
  margin-left: 4rpx;
  font-weight: 600;
}

.streak-desc {
  font-size: 26rpx;
  color: #8494A7;
  margin-top: 4rpx;
}

/* 分享打卡卡片 */
.share-card {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
  border-color: rgba(255, 193, 7, 0.4);
}

.share-card .task-label {
  color: #D4860B;
}

.share-card .task-hint {
  color: #B08D55;
}

.btn-share {
  background: linear-gradient(135deg, #D4860B, #C67D00);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(212, 134, 11, 0.3);
}

.btn-share::after {
  border: none;
}

/* 单元进度区域 */
.unit-section {
  background: linear-gradient(180deg, #FFFFFF 0%, #F5F7FB 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(30, 60, 110, 0.08);
  border: 1rpx solid rgba(180, 195, 220, 0.35);
}

.unit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.unit-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2a3a;
}

.unit-num {
  font-size: 26rpx;
  color: #2B5EA7;
  font-weight: 600;
}

.unit-progress {
  height: 10rpx;
  background: linear-gradient(180deg, #D8DEE8, #CDD4E0);
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.unit-bar {
  height: 100%;
  background: linear-gradient(90deg, #FFD700, #FFC107);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.unit-desc {
  display: block;
  font-size: 24rpx;
  color: #8494A7;
  text-align: center;
}

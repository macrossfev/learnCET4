<view class="container">
  <!-- 完成提示 -->
  <view class="complete-wrap" wx:if="{{completed}}">
    <view class="complete-card card">
      <view class="complete-icon">🎉</view>
      <text class="complete-title">复习完成!</text>
      <view class="complete-stats">
        <view class="stat-item">
          <text class="stat-number">{{words.length}}</text>
          <text class="stat-label">本次复习</text>
        </view>
        <view class="stat-item">
          <text class="stat-number success">{{rememberedCount}}</text>
          <text class="stat-label">已掌握</text>
        </view>
        <view class="stat-item">
          <text class="stat-number warn">{{forgotCount}}</text>
          <text class="stat-label">需再复习</text>
        </view>
      </view>
      <text class="complete-desc" wx:if="{{rememberedCount > 0}}">太棒了！{{rememberedCount}} 个单词已掌握</text>
      <text class="complete-desc" wx:if="{{forgotCount > 0}}">加油！{{forgotCount}} 个单词需要再次复习</text>
      <button class="btn btn-primary mt-lg" bindtap="goBack">返回首页</button>
    </view>
  </view>

  <!-- 复习卡片 -->
  <view class="review-content" wx:else>
    <!-- 顶部进度 -->
    <view class="progress-header">
      <text class="progress-text">{{currentIndex + 1}}/{{words.length}}</text>
      <view class="progress-wrap">
        <view class="progress-bar" style="width: {{(currentIndex + 1) / words.length * 100}}%"></view>
      </view>
    </view>

    <!-- 单词卡片 -->
    <view class="card-area">
      <word-card word="{{words[currentIndex]}}" autoShowDetail="{{true}}" />
    </view>

    <!-- 即时反馈动画 -->
    <view class="feedback-overlay" wx:if="{{showFeedback}}">
      <view class="feedback-bubble {{feedbackType}}">
        <text class="feedback-text">{{feedbackText}}</text>
      </view>
    </view>

    <!-- 底部按钮 -->
    <view class="action-buttons">
      <button class="btn btn-danger action-btn" bindtap="onForgot">忘了</button>
      <button class="btn btn-success action-btn" bindtap="onRemembered">记住了</button>
    </view>
  </view>
</view>

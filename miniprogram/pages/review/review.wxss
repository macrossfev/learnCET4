@import '/styles/common.wxss';

.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #E8EDF5 0%, #F0F2F7 40%, #F0F2F7 100%);
}

/* 进度头部 */
.progress-header {
  margin-bottom: 32rpx;
}

.progress-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: 32rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2B5EA7, #3674B8);
  -webkit-background-clip: text;
  color: transparent;
}

.mode-tag {
  font-size: 24rpx;
  color: #D4860B;
  background: linear-gradient(135deg, rgba(212, 134, 11, 0.15), rgba(212, 134, 11, 0.08));
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 134, 11, 0.3);
}

.progress-wrap {
  height: 8rpx;
  background: linear-gradient(180deg, #D8DEE8, #CDD4E0);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #3674B8, #5A9AD9, #3674B8);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 卡片区域 */
.card-area {
  flex: 1;
  margin-bottom: 20rpx;
}

.review-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8FC 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(30, 60, 110, 0.1);
  border: 1rpx solid rgba(180, 195, 220, 0.4);
}

/* 单词部分 */
.word-section {
  text-align: center;
  margin-bottom: 32rpx;
  position: relative;
}

.word-text {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 12rpx;
}

.phonetic-text {
  display: block;
  font-size: 28rpx;
  color: #8494A7;
}

.audio-btn-wrap {
  margin-top: 20rpx;
}

.audio-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #2B5EA7, #3674B8);
  border-radius: 50%;
  font-size: 36rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(43, 94, 167, 0.3);
}

.audio-btn::after {
  border: none;
}

.audio-btn-hover {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 释义部分 */
.meaning-section {
  position: relative;
  margin-bottom: 24rpx;
}

.meaning-section.hide .meaning-content {
  filter: blur(20rpx);
  pointer-events: none;
}

.meaning-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  z-index: 10;
}

.mask-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.mask-text {
  font-size: 28rpx;
  color: #2B5EA7;
  font-weight: 600;
}

.meaning-content {
  background: linear-gradient(180deg, #F8F9FC, #F0F2F7);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(180, 195, 220, 0.3);
}

.meaning-item {
  margin-bottom: 20rpx;
}

.meaning-item:last-child {
  margin-bottom: 0;
}

.meaning-label {
  font-size: 26rpx;
  color: #6B7B8D;
  font-weight: 600;
  margin-right: 8rpx;
}

.meaning-text {
  font-size: 28rpx;
  color: #1a2a3a;
  line-height: 1.6;
}

.meaning-text.muted {
  color: #8494A7;
  display: block;
  margin-top: 4rpx;
}

/* 掌握程度选择 */
.mastery-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(180, 195, 220, 0.3);
}

.mastery-prompt {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #6B7B8D;
  margin-bottom: 24rpx;
}

.mastery-buttons {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
}

.mastery-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.mastery-btn::after {
  border: none;
}

.mastery-success {
  background: linear-gradient(180deg, #EDFAF0, #E0F5E4);
  border-color: #1A8A5C;
}

.mastery-warning {
  background: linear-gradient(180deg, #FFF6EE, #FFF0E0);
  border-color: #D4860B;
}

.mastery-error {
  background: linear-gradient(180deg, #FDF0F0, #FAE4E4);
  border-color: #C62828;
}

.mastery-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.mastery-label {
  font-size: 26rpx;
  font-weight: 600;
}

.mastery-success .mastery-label {
  color: #1A8A5C;
}

.mastery-warning .mastery-label {
  color: #D4860B;
}

.mastery-error .mastery-label {
  color: #C62828;
}

/* 已选择掌握程度 */
.mastery-selected {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  margin-top: 24rpx;
  background: linear-gradient(180deg, #F0F4FF, #E8EDF8);
  border-radius: 16rpx;
}

.mastery-selected-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.mastery-selected-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2B5EA7;
}

/* 底部按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* 完成页 */
.complete-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 80vh;
}

.complete-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 36rpx;
  width: 100%;
  max-width: 600rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8FC 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(30, 60, 110, 0.15);
  border: 1rpx solid rgba(180, 195, 220, 0.4);
}

.complete-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.complete-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 32rpx;
}

/* 复习报告 */
.review-report {
  width: 100%;
  margin-bottom: 32rpx;
}

.report-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(180, 195, 220, 0.3);
}

.report-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2a3a;
}

.report-date {
  font-size: 24rpx;
  color: #8494A7;
}

.report-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.report-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: linear-gradient(180deg, #F8F9FC, #F0F2F7);
  border-radius: 12rpx;
}

.report-item.success {
  background: linear-gradient(180deg, #EDFAF0, #E0F5E4);
}

.report-item.warning {
  background: linear-gradient(180deg, #FFF6EE, #FFF0E0);
}

.report-item.error {
  background: linear-gradient(180deg, #FDF0F0, #FAE4E4);
}

.item-number {
  font-size: 32rpx;
  font-weight: 700;
  color: #2B5EA7;
  margin-bottom: 6rpx;
}

.report-item.success .item-number {
  color: #1A8A5C;
}

.report-item.warning .item-number {
  color: #D4860B;
}

.report-item.error .item-number {
  color: #C62828;
}

.item-label {
  font-size: 20rpx;
  color: #8494A7;
  text-align: center;
}

/* 掌握率进度条 */
.mastery-rate {
  margin-bottom: 24rpx;
}

.rate-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.rate-label {
  font-size: 26rpx;
  color: #6B7B8D;
}

.rate-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2B5EA7;
}

.rate-bar {
  height: 12rpx;
  background: linear-gradient(180deg, #D8DEE8, #CDD4E0);
  border-radius: 6rpx;
  overflow: hidden;
}

.rate-fill {
  height: 100%;
  background: linear-gradient(90deg, #1A8A5C, #22A06B);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 复习建议 */
.review-suggestion {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(180deg, #FFF8E1, #FFECB3);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.3);
}

.suggestion-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.suggestion-text {
  font-size: 26rpx;
  color: #B08D55;
  line-height: 1.5;
}

/* 反馈动画 */
.feedback-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.feedback-bubble {
  background: #fff;
  border-radius: 48rpx;
  padding: 32rpx 64rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  animation: popIn 0.3s ease-out;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feedback-bubble.success {
  background: linear-gradient(180deg, #EDFAF0, #E0F5E4);
  border: 2rpx solid #1A8A5C;
}

.feedback-bubble.warning {
  background: linear-gradient(180deg, #FFF6EE, #FFF0E0);
  border: 2rpx solid #D4860B;
}

.feedback-bubble.error {
  background: linear-gradient(180deg, #FDF0F0, #FAE4E4);
  border: 2rpx solid #C62828;
}

.feedback-icon {
  font-size: 64rpx;
  margin-bottom: 8rpx;
}

.feedback-text {
  font-size: 36rpx;
  font-weight: 700;
}

.feedback-bubble.success .feedback-text {
  color: #1A8A5C;
}

.feedback-bubble.warning .feedback-text {
  color: #D4860B;
}

.feedback-bubble.error .feedback-text {
  color: #C62828;
}

@keyframes popIn {
  0% {
    opacity: 0;
    transform: scale(0.8);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}

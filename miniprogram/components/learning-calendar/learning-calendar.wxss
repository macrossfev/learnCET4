.calendar-container {
  background: linear-gradient(180deg, #F8F9FC, #FFFFFF);
  border-radius: 16rpx;
  padding: 24rpx;
}

/* 月份导航 */
.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0 24rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #E8EDF5, #D8DEE8);
  border-radius: 50%;
}

.nav-icon {
  font-size: 36rpx;
  color: #2B5EA7;
  font-weight: bold;
  line-height: 1;
}

.month-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2a3a;
}

/* 星期标题 */
.week-header {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(180, 195, 220, 0.3);
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #8494A7;
}

/* 日历网格 */
.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  padding-top: 8rpx;
}

.day-cell {
  width: calc(100% / 7);
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
}

.day-cell.empty {
  visibility: hidden;
}

.day-number {
  font-size: 28rpx;
  color: #1a2a3a;
  z-index: 1;
}

/* 今天标记 */
.day-cell.today {
  background: linear-gradient(135deg, #2B5EA7, #3674B8);
  border-radius: 50%;
}

.day-cell.today .day-number {
  color: #FFFFFF;
  font-weight: 700;
}

/* 打卡标记 */
.day-cell.checked {
  position: relative;
}

.day-cell.checked::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #1A8A5C;
}

.day-cell.today.checked::after {
  background: rgba(255, 255, 255, 0.8);
}

/* 不同状态的颜色 */
.day-cell.learned.checked::after {
  background: #2B5EA7;
}

.day-cell.reviewed.checked::after {
  background: #1A8A5C;
}

.day-cell.both.checked::after {
  background: linear-gradient(90deg, #2B5EA7 50%, #1A8A5C 50%);
}

/* 日期统计数字 */
.day-stats {
  position: absolute;
  bottom: -4rpx;
  display: flex;
  gap: 2rpx;
}

.stat-num {
  font-size: 16rpx;
  color: #2B5EA7;
  background: rgba(43, 94, 167, 0.1);
  padding: 0 4rpx;
  border-radius: 4rpx;
  line-height: 1.2;
}

.stat-num.review {
  color: #1A8A5C;
  background: rgba(26, 138, 92, 0.1);
}

.day-cell.today .stat-num {
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
}

.day-cell.today .stat-num.review {
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.2);
}

/* 图例 */
.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(180, 195, 220, 0.3);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #8494A7;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.learned {
  background: #2B5EA7;
}

.legend-dot.reviewed {
  background: #1A8A5C;
}

.legend-dot.both {
  background: linear-gradient(90deg, #2B5EA7 50%, #1A8A5C 50%);
}
.word-quiz-card {
  background: linear-gradient(180deg, #FFFFFF 0%, #F7F8FC 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(30, 60, 110, 0.1);
  border: 1rpx solid rgba(180, 195, 220, 0.4);
}

/* 单词部分 */
.word-section {
  text-align: center;
  margin-bottom: 32rpx;
  position: relative;
}

.word-text {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #1a2a3a;
  margin-bottom: 12rpx;
}

.phonetic-text {
  display: block;
  font-size: 28rpx;
  color: #8494A7;
}

.audio-btn-wrap {
  margin-top: 20rpx;
}

.audio-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #2B5EA7, #3674B8);
  border-radius: 50%;
  font-size: 36rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(43, 94, 167, 0.3);
}

.audio-btn::after {
  border: none;
}

.audio-btn-hover {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 释义部分 */
.meaning-section {
  position: relative;
  margin-bottom: 24rpx;
}

.meaning-section.hide .meaning-content {
  filter: blur(20rpx);
  pointer-events: none;
}

.meaning-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
  z-index: 10;
}

.mask-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.mask-text {
  font-size: 28rpx;
  color: #2B5EA7;
  font-weight: 600;
}

.meaning-content {
  background: linear-gradient(180deg, #F8F9FC, #F0F2F7);
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(180, 195, 220, 0.3);
}

.meaning-item {
  margin-bottom: 20rpx;
}

.meaning-item:last-child {
  margin-bottom: 0;
}

.meaning-label {
  font-size: 26rpx;
  color: #6B7B8D;
  font-weight: 600;
  margin-right: 8rpx;
}

.meaning-text {
  font-size: 28rpx;
  color: #1a2a3a;
  line-height: 1.6;
}

.meaning-text.muted {
  color: #8494A7;
  display: block;
  margin-top: 4rpx;
}

/* 掌握程度选择 */
.mastery-section {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(180, 195, 220, 0.3);
}

.mastery-prompt {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #6B7B8D;
  margin-bottom: 24rpx;
}

.mastery-buttons {
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
}

.mastery-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.mastery-btn::after {
  border: none;
}

.mastery-success {
  background: linear-gradient(180deg, #EDFAF0, #E0F5E4);
  border-color: #1A8A5C;
}

.mastery-warning {
  background: linear-gradient(180deg, #FFF6EE, #FFF0E0);
  border-color: #D4860B;
}

.mastery-error {
  background: linear-gradient(180deg, #FDF0F0, #FAE4E4);
  border-color: #C62828;
}

.mastery-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.mastery-label {
  font-size: 26rpx;
  font-weight: 600;
}

.mastery-success .mastery-label {
  color: #1A8A5C;
}

.mastery-warning .mastery-label {
  color: #D4860B;
}

.mastery-error .mastery-label {
  color: #C62828;
}

/* 已选择掌握程度 */
.mastery-selected {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  margin-top: 24rpx;
  background: linear-gradient(180deg, #F0F4FF, #E8EDF8);
  border-radius: 16rpx;
}

.mastery-selected-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.mastery-selected-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2B5EA7;
}
